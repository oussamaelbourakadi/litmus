# Backend environment. Copy to .env for local (non-Docker) development.
# The platform boots with NO API key thanks to the Mock and Ollama providers.

ENVIRONMENT=development

# PostgreSQL (async driver). In docker-compose the host is "postgres".
DATABASE_URL=postgresql+asyncpg://litmus:litmus@localhost:5432/litmus

# Redis (used by workers from Phase 1.3 onward).
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional cloud provider keys (leave empty to run fully local / mock).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
