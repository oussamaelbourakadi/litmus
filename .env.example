# Root environment example for docker-compose.
# Copy to .env if you want to override compose defaults. The stack boots with
# NO API key — cloud provider keys below are optional.

POSTGRES_USER=litmus
POSTGRES_PASSWORD=litmus
POSTGRES_DB=litmus

# Optional cloud provider keys (leave empty to run fully local / mock).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
